# Live Mongolian TTS demo (/api/tts). Same RunPod key the Python pipeline uses.
# Server-side only — never exposed to the browser. Copy to .env.local for dev,
# set as an env var in Vercel for prod.
RUNPOD_API_KEY=

# Optional: override the TTS serverless endpoint id (defaults to the demo's).
# RUNPOD_TTS_ENDPOINT_ID=
